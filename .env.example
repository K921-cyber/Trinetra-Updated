# ==================== TRINETRA — Environment Variables ====================
# Copy this file to .env:
#   cp .env.example .env
#
# Docker Compose auto-loads .env from project root.
# Required: POSTGRES_PASSWORD (Docker won't start without it)
# Optional: API_KEY, HIBP_API_KEY (leave empty for dev mode)

# ==================== Database (PostgreSQL - Docker) ====================
POSTGRES_USER=trinetra
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=trinetra

# For local SQLite dev (no Docker), uncomment:
# DATABASE_URL=sqlite+aiosqlite:///./trinetra.db

# ==================== Redis (optional) ====================
# Leave empty = tasks run inline (dev mode)
# For production: redis://redis:6379/0
REDIS_URL=

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ==================== API Authentication ====================
# Leave empty = open access (dev mode).
# Set a strong key to enable auth for production.
# Accepted formats: Authorization: Bearer <key> or X-API-Key: <key>
API_KEY=

# ==================== External API Keys ====================
# Have I Been Pwned v3 API key (optional, for enhanced data leak checks)
# https://haveibeenpwned.com/API/Key
HIBP_API_KEY=
